  "engine_rules": {
    "rule1": "Press key alone (no shift) → vowel or consonant directly",
    "rule2": "Consonant + pulli (KeyF, no shift) → pure consonant (e.g. க + ் = க்)",
    "rule3": "Consonant + vowel key → uyirmei combined character (e.g. க + ஆ = கா)",
    "rule4": "அ is the implicit vowel — consonant alone sounds like consonant+அ",
    "rule5": "Shift is used ONLY for grantha letters and special symbols"
  }
